{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "brasaland: run api",
      "type": "shell",
      "command": "bash",
      "args": [
        "scripts/run_api_local.sh"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "brasaland: stop api",
      "type": "shell",
      "command": "bash",
      "args": [
        "scripts/stop_api_local.sh"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "brasaland: restart api",
      "type": "shell",
      "command": "bash",
      "args": [
        "scripts/restart_api_local.sh"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "brasaland: smoke api",
      "type": "shell",
      "command": "bash",
      "args": [
        "workflows/scripts/smoke_api.sh"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "brasaland: integration api",
      "type": "shell",
      "command": "bash",
      "args": [
        "workflows/scripts/integration_api.sh"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "brasaland: integration data api",
      "type": "shell",
      "command": "bash",
      "args": [
        "workflows/scripts/integration_data_api.sh"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "brasaland: qa all",
      "dependsOrder": "sequence",
      "dependsOn": [
        "brasaland: smoke api",
        "brasaland: integration api",
        "brasaland: integration data api"
      ],
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "brasaland: qa local script",
      "type": "shell",
      "command": "bash",
      "args": [
        "scripts/run_qa_local.sh"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "brasaland: dev cycle",
      "type": "shell",
      "command": "bash",
      "args": [
        "scripts/dev_cycle.sh"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "brasaland: check env",
      "type": "shell",
      "command": "bash",
      "args": [
        "scripts/check_env.sh"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "problemMatcher": []
    }
  ]
}